# ── a2a-gateway environment ──────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Required: PostgreSQL database password (used in docker-compose and DATABASE_URL).
# Generate: openssl rand -hex 16
POSTGRES_PASSWORD=changeme-replace-with-strong-password

# Required (if not using docker-compose DNS): full postgres connection string.
# docker-compose sets this automatically using POSTGRES_PASSWORD above.
# For local dev: DATABASE_URL=postgres://a2a:<password>@localhost/a2a
# DATABASE_URL=postgres://a2a:changeme@localhost/a2a

# Required: HS256 secret used to sign peer-boundary JWTs.
# Generate: openssl rand -hex 32
A2A_JWT_SECRET=changeme-replace-with-32-byte-hex

# Optional: Proxmox API token for LXC spawn/list/stop.
# Format: <user>@<realm>!<token-id>=<uuid>
# Example: root@pam!claude=3bbce3c7-21f1-4cd1-b3b4-aadde6ff7194
A2A_PROXMOX_TOKEN=

# Optional: Entropy Reader webhook URL for iOS push notifications.
# Set to the /api/v1/claude-code/events endpoint on your Entropy Reader server.
# Example: http://192.168.1.67:8080/api/v1/claude-code/events
ENTROPY_WEBHOOK_URL=

# Optional: Bearer token for the Entropy Reader webhook endpoint.
ENTROPY_BEARER_TOKEN=

# Optional: NATS URL (defaults to nats://127.0.0.1:4222 if unset).
# Used for push fan-out notifications. Gateway degrades gracefully if NATS is down.
# NATS_URL=nats://127.0.0.1:4222

# Optional: Override the gateway config file path (default: ./gateway.toml).
# A2A_CONFIG=/etc/a2a/gateway.toml

# Optional: Bearer token for the web dashboard (:7243).
# If set, all dashboard routes require this token.
# Generate: openssl rand -hex 24
# A2A_WEB_TOKEN=

# Optional: NATS authentication (if NATS server requires it).
# NATS_USER=a2a
# NATS_PASSWORD=

# Optional: Anthropic API key for LLM PRD generation (orchestrator agent).
# ANTHROPIC_API_KEY=

# Optional: Cloudflare Tunnel token for public internet access.
# Create with: cloudflared tunnel create a2a-gateway
# Start with: docker compose --profile tunnel up -d
# CF_TUNNEL_TOKEN=

# Optional: OTLP endpoint for OpenTelemetry traces.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
